import sys

def main():
    # Read all input from standard input at once
    input_data = sys.stdin.read().splitlines()
    
    if not input_data:
        return

    n = int(input_data[0].strip())
    
    phone_book = {}
    
    # Process the n phone book entries
    for i in range(1, n + 1):
        name, number = input_data[i].split()
        phone_book[name] = number
        
    # Process the unknown number of queries
    for query in input_data[n + 1:]:
        query = query.strip()
        if not query:
            continue
        
        if query in phone_book:
            print(f"{query}={phone_book[query]}")
        else:
            print("Not found")

if __name__ == '__main__':
    main()
